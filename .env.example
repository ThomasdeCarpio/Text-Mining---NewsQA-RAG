# --- LLM & Embeddings ---
OPENAI_API_KEY="sk-proj-your-api-key-here"

# Cheaper alternative for generation + RAGAS judge. If set, it is preferred over
# OPENAI_API_KEY (OpenAI-compatible; embeddings still run locally, free).
DEEPSEEK_API_KEY="sk-your-deepseek-key-here"

# --- Optional/Advanced APIs ---
# Get free key from cohere.com (For Reranker module)
COHERE_API_KEY="your-cohere-key-here"

# Get free key from newsapi.org (For Live Crawler tool)
NEWS_API_KEY="your-news-api-key-here"

# --- News crawler storage ---
# Create a write token at https://huggingface.co/settings/tokens
HF_TOKEN="hf-your-write-token-here"
HF_BUCKET_ID="your-username/newsqa-crawler"
HF_BUCKET_PRIVATE="true"
HF_BUCKET_PREFIX=""
CRAWLER_STORAGE="hf-bucket"

# --- LangSmith Tracing (Highly recommended for debugging LangChain agents) ---
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your-langchain-key-here"
LANGCHAIN_PROJECT="NewsQA_RAG"

# --- Database & Local Embedding models ---

DATA_DIR="database/"
